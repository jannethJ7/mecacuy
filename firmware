const unsigned long STEPPER_HALF_PERIOD_US = 3000;

float clampf(float x, float a, float b) {
  if (x < a) return a;
  if (x > b) return b;
  return x;
}

float mapFloat(float x, float inMin, float inMax, float outMin, float outMax) {
  if (fabs(inMax - inMin) < 0.0001f) return outMin;
  return (x - inMin) * (outMax - outMin) / (inMax - inMin) + outMin;
}

float jsonFloat(JsonVariant v, float def) {
  if (v.isNull()) return def;
  if (v.is<float>() || v.is<double>() || v.is<int>() || v.is<long>()) return v.as<float>();
  String s = v.as<String>();
  if (s.length() == 0) return def;
  return s.toFloat();
}

String lowerStr(String s) {
  s.toLowerCase();
  return s;
}

bool validGpio(int gpio) {
  return gpio >= 0 && gpio <= 39;
}

bool isOutputCapable(int gpio) {
  if (!validGpio(gpio)) return false;
  if (gpio >= 34 && gpio <= 39) return false;
  if (gpio >= 6 && gpio <= 11) return false;
  return true;
}

String nowIso() {
  if (!timeReady) return "";
  struct tm tinfo;
  if (!getLocalTime(&tinfo, 50)) return "";
  char buf[32];
  strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &tinfo);
  return String(buf);
}

ActuatorCfg* findActuator(const String& codigo) {
  for (int i = 0; i < actuatorCount; i++) {
    if (actuators[i].codigo == codigo) return &actuators[i];
  }
  return nullptr;
}

SensorCfg* findSensor(const String& codigo) {
  for (int i = 0; i < sensorCount; i++) {
    if (sensors[i].codigo == codigo) return &sensors[i];
  }
  return nullptr;
}

void initNTP() {
  configTime(GMT_OFFSET_SEC, DAYLIGHT_OFFSET_SEC, NTP1, NTP2);

  struct tm tinfo;
  for (int i = 0; i < 20; i++) {
    if (getLocalTime(&tinfo, 200)) {
      timeReady = true;
      Serial.println("NTP OK");
      return;
    }
    delay(200);
  }

  timeReady = false;
  Serial.println("NTP no disponible");
}

void ensureWiFi() {
  if (WiFi.status() == WL_CONNECTED) return;

  unsigned long nowMs = millis();
  if (nowMs - lastWifiTryMs < WIFI_RETRY_MS) return;
  lastWifiTryMs = nowMs;

  Serial.println("Reintentando WiFi...");
  WiFi.disconnect();
  WiFi.begin(WIFI_SSID, WIFI_PASS);
}

void addIotHeaders(HTTPClient& http) {
  http.addHeader("Accept", "application/json");
  http.addHeader("X-MODULO-UID", MODULO_UID);
  http.addHeader("X-DEVICE-KEY", DEVICE_KEY);
  http.addHeader("X-FW", FW_VERSION);

  if (WiFi.status() == WL_CONNECTED) {
    http.addHeader("X-RSSI", String(WiFi.RSSI()));
  }
}

bool httpGET(const String& url, String& out) {
  if (WiFi.status() != WL_CONNECTED) return false;

  HTTPClient http;
  http.setTimeout(5000);
  http.useHTTP10(true);
  http.begin(url);
  addIotHeaders(http);

  int code = http.GET();
  if (code > 0) out = http.getString();

  Serial.print("GET ");
  Serial.print(url);
  Serial.print(" -> ");
  Serial.println(code);

  if (code > 0) Serial.println(out);

  http.end();
  return code == 200;
}

bool httpPOSTJson(const String& url, const String& body, String& out) {
  if (WiFi.status() != WL_CONNECTED) return false;

  HTTPClient http;
  http.setTimeout(5000);
  http.useHTTP10(true);
  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  addIotHeaders(http);

  int code = http.POST(body);
  if (code > 0) out = http.getString();

  Serial.print("POST ");
  Serial.print(url);
  Serial.print(" -> ");
  Serial.println(code);

  if (code > 0) Serial.println(out);

  http.end();
  return code == 200 || code == 201;
}

